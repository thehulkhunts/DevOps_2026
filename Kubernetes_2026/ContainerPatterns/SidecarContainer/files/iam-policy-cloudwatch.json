{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "FluentBitCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogStreams",
        "logs:DescribeLogGroups"
      ],
      "Resource": [
        "arn:aws:logs:ap-south-1:123456789012:log-group:/eks/sidecar-demo/*"
      ]
    }
  ]
}
